<!DOCTYPE html>
<html lang="sq">
<head>
    <link rel="stylesheet" href="/style.css">
    <title>Kyçu - Kinema AAB</title>
</head>
<body>
    <header><a href="/" class="logo">Kinema AAB</a></header>
    
    <div class="login-box">
        <h2>Mirësevini</h2>
        <form action="/login" method="POST">
            <div class="form-group">
                <label>Email Adresa</label>
                <input type="email" name="email" required placeholder="shembull@email.com">
            </div>
            <div class="form-group">
                <label>Fjalëkalimi</label>
                <input type="password" name="fjalekalimi" required placeholder="********">
            </div>
            <button type="submit" class="btn-rezervo" style="border:none; cursor:pointer;">Kyçu</button>
        </form>
        <p style="margin-top: 15px;">Nuk keni llogari? <a href="/register" style="color: #e50914;">Regjistrohuni këtu</a></p>
    </div>
</body>
</html>